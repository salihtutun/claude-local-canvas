{
  "name": "canvas-local-canvas",
  "version": "1.0.0",
  "description": "An MCP server that gives Claude a local web server and a headless browser for live app previews and console debugging",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "canvas-local-canvas": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --minify",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "puppeteer",
    "preview",
    "canvas"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "puppeteer": "^22.12.1",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
